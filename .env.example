# Supabase connection for the frontend.
# These are PUBLIC (anon) values and are safe to expose in a static site.
# NEVER put the service_role key here.

# OB FAQ/KK project (auth login_codes + kk_problems tables)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# OB Artyom project (accounting_activities, ob_accounting_companies,
# accountant_daily_comments, document_records, artem_companies)
# Requires SELECT RLS policies on these tables for the anon role.
# Also powers the «Сравнение с базой» panels + the daily analysis (see 0034).
VITE_ARTYOM_SUPABASE_URL=https://YOUR-ARTYOM-PROJECT-ref.supabase.co
VITE_ARTYOM_SUPABASE_ANON_KEY=your-artyom-anon-key

# Edge function daily-db-analysis-telegram (0034) reads the Artyom project too,
# via its OWN secrets (set with `supabase secrets set …`, NOT in this file):
#   ARTYOM_SUPABASE_URL, ARTYOM_SUPABASE_ANON_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID

# Main OB project (CRM deals / sdelki — OB table).
# Falls back to hardcoded public defaults if not set (anon key, safe to omit).
VITE_MAIN_SUPABASE_URL=https://ntdngelbzojoqoknovnh.supabase.co
VITE_MAIN_SUPABASE_ANON_KEY=your-main-anon-key
